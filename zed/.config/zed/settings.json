// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "show_wrap_guides": false,
  "indent_guides": {
    "enabled": false,
  },
  "git_panel": {
    "tree_view": true,
  },
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "telemetry": {
    "diagnostics": true,
    "metrics": false,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "vim_mode": true,
  "relative_line_numbers": "enabled",
  "sticky_scroll": {
    "enabled": false,
  },
  "vertical_scroll_margin": 8.0,
  "gutter": {
    "line_numbers": true,
  },
  "minimap": {
    "show": "never",
  },
  "cursor_blink": false,
  "auto_indent_on_paste": true,
  "show_whitespaces": "none",
  "base_keymap": "VSCode",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Tokyo Night",
  },
  "theme_overrides": {
    "Tokyo Night": {
      "editor.background": "#000",
      "panel.background": "#000",
      "elevated_surface.background": "#000",
      "surface.background": "#000",
      "background": "#000",
      "status_bar.background": "#000",
      "toolbar.background": "#000",
      "tab_bar.background": "#000",
      "editor.gutter.background": "#000",
      "editor.subheader.background": "#000",
      "editor.active_line.background": "#000",
      "terminal.background": "#000",
      "scrollbar.track.background": "#000",
      }
    }
  }
}
